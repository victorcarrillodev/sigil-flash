[Unit]
Description=Sigil Bluetooth Auto Connect
# Start reconnect as soon as BlueZ is ready.  PulseAudio starts in parallel;
# bt-connect waits for its A2DP endpoint only after attempting the preferred
# speaker connection.
After=bluetooth.service bluetooth.target
Wants=bluetooth.service sigil-pulseaudio.service
# Reiniciar indefinidamente si falla (la Pi puede no tener Bluetooth listo de inmediato)
StartLimitIntervalSec=0

[Service]
Type=simple
User=sigil
Group=sigil
ExecStart=/usr/local/bin/bt-connect.sh
Restart=on-failure
RestartSec=15
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
