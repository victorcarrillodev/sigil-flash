{
  "comment": "Source → destination mapping for Sigil OS payload",
  "version": "2.1",
  "source_base": "sigil-hardware",
  "entries": [
    {
      "source": "panel/*.py",
      "destination": "/opt/sigil/panel/",
      "type": "file",
      "owner": "root:root",
      "mode": "644",
      "description": "Root-owned Flask application files"
    },
    {
      "source": "panel/templates/",
      "destination": "/opt/sigil/panel/templates/",
      "type": "directory",
      "owner": "root:root",
      "mode": "755",
      "description": "Jinja2 HTML templates"
    },
    {
      "source": "panel/static/",
      "destination": "/opt/sigil/panel/static/",
      "type": "directory",
      "owner": "root:root",
      "mode": "755",
      "description": "Static assets (CSS, JS)"
    },
    {
      "source": "panel/device_identity.py",
      "destination": "/home/sigil/device_identity.py",
      "type": "file",
      "owner": "root:root",
      "mode": "644",
      "description": "Compatibility helper for non-root runtime scripts"
    },
    {
      "sources": [
        "scripts/bt-connect.sh",
        "scripts/radio-stream.sh",
        "scripts/set-a2dp.sh",
        "scripts/sigil-leds.sh",
        "scripts/sigil-wifi-control.py",
        "scripts/wifi-fallback.sh",
        "scripts/wifi-manager.sh",
        "scripts/audio-manager.sh",
        "scripts/radio-fetcher.sh",
        "scripts/audio-player.sh",
        "scripts/sigil-validate-state.sh",
        "scripts/sigil-healthcheck.sh",
        "scripts/sigil-audio-route.sh",
        "scripts/sigil-audio-capability.sh",
        "scripts/sigil-cache-meta-perms.sh",
        "scripts/sigil-cache-wipe.sh",
        "scripts/sigil-logout-fetch-operation.sh",
        "scripts/ssh-monitor.sh",
        "scripts/firstboot.sh"
      ],
      "destination": "/usr/local/bin/",
      "type": "file",
      "owner": "root:root",
      "mode": "755",
      "executable": true,
      "description": "System shell scripts"
    },
    {
      "source": "services/*.service",
      "destination": "/etc/systemd/system/",
      "type": "file",
      "owner": "root:root",
      "mode": "644",
      "description": "Systemd service units"
    },
    {
      "source": "conf/bluetooth-main.conf",
      "destination": "/etc/bluetooth/main.conf",
      "type": "file",
      "owner": "root:root",
      "mode": "644",
      "description": "BlueZ configuration"
    },
    {
      "source": "conf/pulse-daemon.conf",
      "destination": "/etc/pulse/daemon.conf",
      "type": "file",
      "owner": "root:root",
      "mode": "644",
      "description": "PulseAudio daemon config"
    },
    {
      "source": "conf/dnsmasq.conf",
      "destination": "/etc/dnsmasq.conf",
      "type": "file",
      "owner": "root:root",
      "mode": "644",
      "description": "DHCP server for AP mode"
    },
    {
      "source": "conf/hostapd.conf",
      "destination": "/etc/hostapd/hostapd.conf",
      "type": "file",
      "owner": "root:root",
      "mode": "644",
      "description": "WiFi AP configuration"
    },
    {
      "source": "conf/sigil-network.sudoers",
      "destination": "/etc/sudoers.d/sigil-network",
      "type": "file",
      "owner": "root:root",
      "mode": "440",
      "description": "Sudo rules for panel"
    },
    {
      "source": "conf/sigil.sudoers",
      "destination": "/etc/sudoers.d/sigil",
      "type": "file",
      "owner": "root:root",
      "mode": "440",
      "description": "Sudo rules for SIGIL maintenance helpers"
    },
    {
      "source": "conf/sigil-tmpfiles.conf",
      "destination": "/etc/tmpfiles.d/sigil.conf",
      "type": "file",
      "owner": "root:root",
      "mode": "644",
      "description": "Runtime directory ownership contract"
    },
    {
      "source": "conf/90-sigil-persistent-journal.conf",
      "destination": "/etc/systemd/journald.conf.d/90-sigil-persistent.conf",
      "type": "file",
      "owner": "root:root",
      "mode": "644",
      "description": "Bounded persistent systemd journal configuration"
    },
    {
      "source": "conf/sigil-logrotate",
      "destination": "/etc/logrotate.d/sigil",
      "type": "file",
      "owner": "root:root",
      "mode": "644",
      "description": "Bounded rotation for legacy SIGIL file logs"
    },
    {
      "source": "conf/90-sigil-geolocate",
      "destination": "/etc/NetworkManager/dispatcher.d/90-sigil-geolocate",
      "type": "file",
      "owner": "root:root",
      "mode": "755",
      "executable": true,
      "description": "NetworkManager geolocation dispatcher"
    },
    {
      "source": "conf/99-sigil-mac-fixed.conf",
      "destination": "/etc/NetworkManager/conf.d/99-sigil-mac-fixed.conf",
      "type": "file",
      "owner": "root:root",
      "mode": "644",
      "description": "Disable MAC randomization"
    },
    {
      "source": "conf/audio.conf",
      "destination": "/etc/sigil/audio.conf",
      "type": "file",
      "owner": "root:sigil",
      "mode": "640",
      "description": "Audio system configuration"
    },
    {
      "source": "conf/security.conf",
      "destination": "/etc/sigil/security.conf",
      "type": "file",
      "owner": "root:root",
      "mode": "600",
      "description": "Security configuration"
    },
    {
      "source": "conf/wifi-fallback.conf",
      "destination": "/etc/sigil/wifi-fallback.conf",
      "type": "file",
      "owner": "root:root",
      "mode": "644",
      "description": "WiFi fallback hysteresis and connectivity probe configuration"
    }
  ]
}
