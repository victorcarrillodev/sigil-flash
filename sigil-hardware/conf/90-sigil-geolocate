#!/bin/bash
# 90-sigil-geolocate — NetworkManager dispatcher for SIGIL WiFi geolocation
# Installed to /etc/NetworkManager/dispatcher.d/90-sigil-geolocate
# Triggered automatically by NetworkManager on interface events.
# =============================================================================
# Only reacts to wlan0 'up' events. Runs geolocation asynchronously.
# Failure is non-critical: never blocks the dispatcher or other services.

INTERFACE="$1"
ACTION="$2"

# Only wlan0 connectivity events — ignore loopback, Ethernet, and other actions
[ "$INTERFACE" != "wlan0" ] && exit 0
[ "$ACTION" != "up" ] && exit 0

# Geolocation is opt-in. Keep the dispatcher installed for manufacturing
# images, but never transmit a WiFi scan unless explicitly enabled.
GEO_CONFIG="${SIGIL_GEO_CONFIG:-/etc/sigil/audio.conf}"
if [ -z "${SIGIL_GEO_SCRIPT:-}" ] && [ -f "$GEO_CONFIG" ]; then
    GEO_ENABLED=$(awk -F= '/^[[:space:]]*SIGIL_GEOLOCATION_ENABLED[[:space:]]*=/{v=$2; gsub(/^[[:space:]"\047]+|[[:space:]"\047]+$/, "", v); print tolower(v); exit}' "$GEO_CONFIG")
    [ "$GEO_ENABLED" = "true" ] || exit 0
fi

# Production defaults; overrides exist only to permit isolated execution of this
# exact dispatcher in the repository test suite.
GEO_DELAY_SECONDS="${SIGIL_GEO_DELAY_SECONDS:-5}"
GEO_PYTHON="${SIGIL_GEO_PYTHON:-/usr/bin/python3}"
GEO_SCRIPT="${SIGIL_GEO_SCRIPT:-/opt/sigil/panel/geolocation.py}"
GEO_LOG="${SIGIL_GEO_LOG:-/var/log/sigil-geolocate.log}"

# Delay and worker both run asynchronously — NetworkManager returns immediately.
(
    sleep "$GEO_DELAY_SECONDS"
    exec "$GEO_PYTHON" "$GEO_SCRIPT"
) </dev/null >>"$GEO_LOG" 2>&1 &

exit 0
