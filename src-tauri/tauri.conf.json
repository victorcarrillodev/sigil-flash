{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sigil Flash",
  "identifier": "com.sigil.flash",
  "version": "0.1.0",
  "build": {
    "beforeDevCommand": "bun dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Sigil Flash",
        "width": 960,
        "height": 660,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 560,
        "decorations": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
